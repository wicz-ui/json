-- Consulta 1
SELECT
    JSON_UNQUOTE(JSON_EXTRACT(doc, '$.Name')) AS pais,
    JSON_EXTRACT(doc, '$.demographics.LifeExpectancy') AS expectativa_vida
FROM countryinfo
WHERE JSON_UNQUOTE(JSON_EXTRACT(doc, '$.geography.Continent')) = 'South America';

-- Consulta 2
SELECT
    c.Name AS pais,
    JSON_EXTRACT(ci.doc, '$.GNP') AS gnp
FROM country c
JOIN countryinfo ci
    ON c.Code = JSON_UNQUOTE(JSON_EXTRACT(ci.doc, '$.Code'))
JOIN countrylanguage cl
    ON cl.CountryCode = c.Code
WHERE JSON_EXTRACT(ci.doc, '$.GNP') > 500000
  AND cl.Language = 'English'
  AND cl.IsOfficial = 'T';

USE empresa;

-- Consulta 3
SELECT
    CONCAT_WS(' ', f.PRIMEIRO_NOME, f.NOME_MEIO, f.ULTIMO_NOME) AS nome_funcionario,
    o.`JSON` AS conteudo_json
FROM tb_funcionario f
JOIN tb_object_funcionario o
    ON o.CPF = f.CPF
WHERE JSON_SEARCH(
          o.`JSON`,
          'one',
          'Feminino',
          NULL,
          '$.dependentes[*].sexo'
      ) IS NOT NULL;

-- Consulta 4
SELECT
    CONCAT_WS(' ', f.PRIMEIRO_NOME, f.NOME_MEIO, f.ULTIMO_NOME) AS nome_funcionario,
    d.nome AS nome_dependente,
    d.parentesco,
    d.data_nascimento
FROM tb_funcionario f
JOIN tb_object_funcionario o
    ON o.CPF = f.CPF
CROSS JOIN JSON_TABLE(
    o.`JSON`,
    '$.dependentes[*]'
    COLUMNS (
        nome VARCHAR(100) PATH '$.nome',
        parentesco VARCHAR(50) PATH '$.parentesco',
        data_nascimento DATE PATH '$.data_nascimento'
    )
) AS d;
