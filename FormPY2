<!DOCTYPE html>
<html lang="pt-BR">


<head>
   <meta charset="UTF-8" />
   <meta name="viewport" content="width=device-width, initial-scale=1.0" />
   <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
   <title>Cadastro de Cliente</title>
</head>


<body>
   <h1>Cadastro de Cliente</h1>


   <form action="/cadastrar" method="post">
       <label for="cpf">CPF:</label>
       <input type="text" id="cpf" name="cpf" maxlength="11" required>


       <label for="primeiro_nome">Primeiro nome:</label>
       <input type="text" id="primeiro_nome" name="primeiro_nome" required>


       <label for="sobrenome">Sobrenome:</label>
       <input type="text" id="sobrenome" name="sobrenome" required>


       <label for="idade">Idade:</label>
       <input type="number" id="idade" name="idade" required>


       <button type="submit">Cadastrar</button>
   </form>


   <h2>Clientes cadastrados</h2>


   <div class="tabela-container">
       <table>
           <thead>
               <tr>
                   <th>CPF</th>
                   <th>Primeiro Nome</th>
                   <th>Sobrenome</th>
                   <th>Idade</th>
                   <th>Ação</th>
               </tr>
           </thead>


           <tbody>
               {% for cliente in clientes %}
               <tr>
                   <td>{{ cliente.CPF }}</td>
                   <td>{{ cliente.PRIMEIRO_NOME }}</td>
                   <td>{{ cliente.SOBRENOME }}</td>
                   <td>{{ cliente.IDADE }}</td>
                   <td>
                       <form action="{{ url_for('deletar', cpf=cliente.CPF) }}" method="post" class="form-deletar">
                           <button type="submit" class="btn-deletar">Excluir</button>
                       </form>
                   </td>
               </tr>
               {% else %}
               <tr>
                   <td colspan="5">Nenhum cliente cadastrado.</td>
               </tr>
               {% endfor %}
           </tbody>
       </table>
   </div>
   {% with mensagens = get_flashed_messages() %}
   {% if mensagens %}
   <div class="popup-fundo" id="popup">
       <div class="popup-caixa">
           <h3>Sucesso!</h3>
           <p>{{ mensagens[0] }}</p>
           <button onclick="fecharPopup()">OK</button>
       </div>
   </div>
   {% endif %}
   {% endwith %}


   <script>
       function fecharPopup() {
           const popup = document.getElementById("popup");
           if (popup) {
               popup.style.display = "none";
           }
       }
   </script>
</body>


</html>

